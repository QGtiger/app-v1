# ====================== 全局配置（放在最顶部） ======================
# 隐藏Nginx版本号（全局生效，比每个server块写更高效）
server_tokens off;

# ====================== 1. HTTP 80端口：统一强制跳转到HTTPS ======================
server {
    listen 80;
    server_name lightfish.top *.lightfish.top; # 匹配所有域名和子域名
    return 301 https://$host$request_uri; # 永久重定向，保留原路径和参数
}

# ====================== 2. HTTPS 443端口：api.lightfish.top（3001端口） ======================
server {
    listen 443 ssl http2;
    server_name api.lightfish.top; # 精确匹配API子域名

    # SSL证书路径（和你之前安装的路径完全一致）
    ssl_certificate /etc/nginx/ssl/lightfish.top/fullchain.pem;
    ssl_certificate_key /etc/nginx/ssl/lightfish.top/privkey.pem;

    # 推荐的SSL安全配置（A+评级）
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;

    # GZIP压缩配置
    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level 6;
    gzip_types text/plain text/css text/xml text/javascript
               application/json application/javascript application/xml+rss
               application/xhtml+xml image/svg+xml;

    # 反向代理到3001端口（你的API服务）
    location / {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_connect_timeout 30s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
        proxy_buffering off;
    }

    # 安全头部
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header X-Content-Type-Options "nosniff" always;
}

# ====================== 3. HTTPS 443端口：泛域名（3000端口） ======================
server {
    listen 443 ssl http2;
    server_name *.lightfish.top lightfish.top; # 匹配根域名和所有其他子域名

    # 复用相同的SSL证书（泛域名证书支持所有子域名）
    ssl_certificate /etc/nginx/ssl/lightfish.top/fullchain.pem;
    ssl_certificate_key /etc/nginx/ssl/lightfish.top/privkey.pem;

    # 相同的SSL安全配置
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;

    # GZIP压缩配置
    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level 6;
    gzip_types
        text/plain
        text/css
        text/xml
        text/javascript
        application/json
        application/javascript
        application/xml+rss
        application/xhtml+xml
        image/svg+xml;

    # 反向代理到3000端口（你的主应用）
    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_connect_timeout 30s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
        proxy_buffering off;
    }

    # 安全头部
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header X-Content-Type-Options "nosniff" always;
}